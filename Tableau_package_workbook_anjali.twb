      <aliases enabled='yes' />
      <column caption='Cumulative%' datatype='real' name='[Calculation_197032510364553216]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([price(INR)]))/TOTAL(SUM([price(INR)]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Formatted_Release_date' datatype='datetime' name='[Calculation_825284658028949504]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='IF ISDATE([release date]) &#13;&#10;THEN DATE([release date]) &#13;&#10;ELSE DATEPARSE(&quot;dd/MM/yyyy&quot;, [release date]) &#13;&#10;END' />
      </column>
      <column caption='Perfomance_per_Price' datatype='real' name='[Calculation_898186677037453312]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[performance] / [price(INR)]' />
      </column>
      <column caption='Price_Category' datatype='string' name='[Calculation_898186677037846529]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [price(INR)] &lt; 20000 THEN &quot;Budget&quot;&#13;&#10;ELSEIF [price(INR)] &lt; 50000 THEN &quot;Mid-range&quot;&#13;&#10;ELSE &quot;Premium&quot;&#13;&#10;END' />
      </column>
      <column caption='Camera_Score' datatype='real' name='[Calculation_898186677038354434]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([main camera] + [selfie camera])/2' />
      </column>
      <column caption='Battery_Performance' datatype='real' name='[Calculation_898186677038907395]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[performance]/[battery size]' />
      </column>
      <column caption='Salary VS Price' datatype='real' name='[Calculation_898186677039071236]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Salary_in_INR]/ [price(INR)]' />
      </column>
      <column caption='Age_Group' datatype='string' name='[Calculation_898186677039292421]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [age] &lt; 25 THEN &quot;Youth (&lt;25)&quot;&#13;&#10;ELSEIF [age] &lt;= 40 THEN &quot;Adult (25-40)&quot;&#13;&#10;ELSEIF [age] &lt;= 60 THEN &quot;Mature (41-60)&quot;&#13;&#10;ELSE &quot;Senior (60+)&quot;&#13;&#10;END' />
      </column>
      <column caption='RAM_Performance' datatype='string' name='[Calculation_898186677039558662]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [RAM] &lt;= 4 THEN &quot;Low RAM&quot;&#13;&#10;ELSEIF [RAM] &lt;= 8 THEN &quot;Medium RAM&quot;&#13;&#10;ELSE &quot;High RAM&quot;&#13;&#10;END' />
      </column>
      <column caption='Release_Year' datatype='integer' name='[Calculation_898186677039845383]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='YEAR([Calculation_825284658028949504])' />
      </column>
      <column aggregation='None' datatype='integer' name='[Internal Memory (bin)]' role='dimension' type='quantitative'>
        <calculation class='bin' decimals='2' formula='[internal memory]' peg='0' size='103.8' />
      </column>
